{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://barry.local/schemas/integration-manifest.schema.json",
  "title": "Barry Integration Manifest",
  "description": "Per-session source of truth for installed skills and third-party integrations available to Barry.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "updated_at",
    "integrations"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "integrations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/integration"
      }
    }
  },
  "$defs": {
    "category": {
      "type": "string",
      "enum": [
        "coding",
        "image_generation",
        "video_generation",
        "data_analysis",
        "file_understanding",
        "ads",
        "crm",
        "analytics",
        "automation",
        "project_management",
        "content",
        "communications",
        "storage",
        "other"
      ]
    },
    "connectionStatus": {
      "type": "string",
      "enum": [
        "connected",
        "available",
        "disconnected",
        "disabled",
        "error"
      ]
    },
    "consequentialAction": {
      "type": "string",
      "enum": [
        "spend_money",
        "publish_external",
        "deploy_production",
        "delete_data",
        "send_external",
        "modify_billing",
        "connect_paid_service"
      ]
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "category",
        "status",
        "description",
        "auth",
        "capabilities"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "$ref": "#/$defs/category"
        },
        "status": {
          "$ref": "#/$defs/connectionStatus"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "auth": {
          "$ref": "#/$defs/auth"
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/capability"
          }
        },
        "last_used_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "connected"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "connected": {
          "type": "boolean"
        },
        "connection_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "example_trigger_phrases"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "example_trigger_phrases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requires_confirmation": {
          "type": "boolean",
          "default": false
        },
        "consequential_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/consequentialAction"
          },
          "uniqueItems": true
        }
      }
    }
  }
}

